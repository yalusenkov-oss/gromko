# ─── Database (PostgreSQL) ───
# Render: set DATABASE_URL to your Postgres Internal URL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Optional alternative to DATABASE_URL:
# PGHOST=HOST
# PGPORT=5432
# PGUSER=USER
# PGPASSWORD=PASSWORD
# PGDATABASE=DBNAME

# Optional: force-disable DB SSL (not recommended in production)
# DATABASE_SSL=false

# ─── JWT ───
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=30d

# ─── Server ───
PORT=3001
HOST=0.0.0.0

# ─── Import Services ───
# Required for Yandex Music URL import (/api/submissions/yandex)
YANDEX_MUSIC_TOKEN=your-yandex-music-token

# Spotify import helper service:
# 1) Set SPOTIFLAC_URL if you run SpotiFLAC as a separate service
# 2) OR set SPOTIFLAC_BIN to a local prebuilt server binary path
# 3) OR set SPOTIFLAC_DIR to a directory that contains cmd/server/main.go
# SPOTIFLAC_URL=http://127.0.0.1:3099
# SPOTIFLAC_BIN=/app/SpotiFLAC-main/bin/spotiflac-server-linux-amd64
# SPOTIFLAC_DIR=/app/server/SpotiFLAC-main
# Optional: auto-install local Go runtime (Linux) if Go is not present
# SPOTIFLAC_AUTO_INSTALL_GO=1
# SPOTIFLAC_GO_VERSION=1.22.12

# ─── Yandex Object Storage (S3) ───
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=your-bucket
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# ─── CDN ───
S3_CDN_BUCKET=your-bucket
S3_CDN_PREFIX=cdn
S3_CDN_URL=https://storage.yandexcloud.net/your-bucket
